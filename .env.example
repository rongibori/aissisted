# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no setup required)
DATABASE_URL="file:./data/aissisted.db"
# PostgreSQL (for Docker / production — use docker-compose.yml or a managed host)
# DATABASE_URL="postgresql://aissisted:aissisted@localhost:5432/aissisted"

# ─── API server ───────────────────────────────────────────────────────────────
PORT=4000
API_HOST="0.0.0.0"
NODE_ENV="development"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET="change-me-in-production"

# ─── Token encryption (required in production) ───────────────────────────────
# AES-256-GCM key for encrypting OAuth2 tokens at rest (HIPAA compliance).
# Must be exactly 32 bytes, base64-encoded.
# Generate with: openssl rand -base64 32
# A dev fallback key is used automatically when NODE_ENV != "production".
TOKEN_ENCRYPTION_KEY=""

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API in production.
# In dev (NODE_ENV != "production") this is ignored — all origins are allowed.
# Example:
# ALLOWED_ORIGINS="https://aissisted.com,https://app.aissisted.com"
ALLOWED_ORIGINS=""

# ─── AI (required) ────────────────────────────────────────────────────────────
# OpenAI — primary brain + Realtime voice (Jeffrey).
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# OpenAI Realtime model override. Default is fine for most cases.
# OPENAI_JEFFREY_REALTIME_MODEL="gpt-4o-realtime-preview"

# Anthropic — fallback for the legacy chat path and intent parser (Haiku).
# Optional while we finish migrating. Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ─── Voice (optional) ─────────────────────────────────────────────────────────
# ElevenLabs streaming TTS — powers /v1/jeffrey/voice/tts.
# When unset the endpoint responds 503 and the app falls back to OpenAI voice.
ELEVENLABS_API_KEY=""
ELEVENLABS_JEFFREY_VOICE_ID=""

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API.
# Local dev: http://localhost:4000
# Production: set in Vercel project env, pointing at the hosted API origin.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── WHOOP integration (optional) ────────────────────────────────────────────
# Register at https://developer.whoop.com/
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
# Redirect URI must match what you registered in the WHOOP developer portal
WHOOP_REDIRECT_URI="http://localhost:4000/integrations/whoop/callback"

# ─── FHIR / Epic integration (optional) ──────────────────────────────────────
# Register a SMART on FHIR app with your EHR vendor (e.g. Epic App Orchard)
FHIR_BASE_URL=""
FHIR_CLIENT_ID=""
FHIR_REDIRECT_URI="http://localhost:4000/integrations/fhir/callback"
