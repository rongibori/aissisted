{
  "name": "@aissisted/orchestrator",
  "version": "0.0.1",
  "description": "Voice → semantic intent → system state → visual response → product behavior. The intelligence bridge between Jeffrey's voice layer and the AISSISTED visualization + product surfaces.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./state": {
      "types": "./src/state/index.ts",
      "import": "./src/state/index.ts"
    },
    "./classifier": {
      "types": "./src/classifier/index.ts",
      "import": "./src/classifier/index.ts"
    },
    "./adapters": {
      "types": "./src/adapters/index.ts",
      "import": "./src/adapters/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "react": "^19.2.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
