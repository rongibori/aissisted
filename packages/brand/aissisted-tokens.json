{
  "$description": "Aissisted Design System — single source of truth for tokens. Mirrors aissisted-system.html (Claude Design canvas canon). Import into Figma via Tokens Studio plugin. Compile to CSS/Tailwind via Style Dictionary or consume directly via Tailwind v4 @theme.",
  "$version": "0.1.0",
  "$canon": "aissisted-system.html",
  "color": {
    "primitive": {
      "white": {
        "$value": "#FFFFFF",
        "$type": "color",
        "$description": "Pure white — default app background; 70% palette ratio"
      },
      "graphite": {
        "100": { "$value": "#F5F5F4", "$type": "color" },
        "200": { "$value": "#E5E5E4", "$type": "color" },
        "300": { "$value": "#C9C9C7", "$type": "color" },
        "400": { "$value": "#A3A3A1", "$type": "color" },
        "500": { "$value": "#707070", "$type": "color" },
        "600": { "$value": "#4A4A4A", "$type": "color" },
        "700": { "$value": "#2E2E2E", "$type": "color", "$description": "Soft Graphite — elevation, secondary surfaces, button hover" },
        "800": { "$value": "#1C1C1E", "$type": "color", "$description": "Graphite — primary text, primary CTA fill, dark Jeffrey card background; 20% palette ratio" },
        "900": { "$value": "#0A0A0A", "$type": "color" }
      },
      "signalRed": {
        "100": { "$value": "#FCDADC", "$type": "color" },
        "300": { "$value": "#F58E94", "$type": "color" },
        "500": { "$value": "#F04450", "$type": "color" },
        "700": { "$value": "#EE2B37", "$type": "color", "$description": "Signal Red — bright matte; emphasis only (max 2 elements per surface, destructive intent); 8% palette ratio" },
        "900": { "$value": "#A11A22", "$type": "color" }
      },
      "aqua": {
        "100": { "$value": "#CCEFF3", "$type": "color" },
        "300": { "$value": "#66D6E0", "$type": "color" },
        "500": { "$value": "#00C2D1", "$type": "color", "$description": "Aqua — data, intelligence, key metrics, Jeffrey 'j' avatar; never decorative; 2% palette ratio" },
        "700": { "$value": "#008A95", "$type": "color" },
        "900": { "$value": "#00525A", "$type": "color" }
      },
      "midnight": {
        "300": { "$value": "#3A4A6B", "$type": "color" },
        "500": { "$value": "#1B2D52", "$type": "color" },
        "700": { "$value": "#0B1D3A", "$type": "color", "$description": "Midnight — voice orb gradient outer edge, cinematic transitions only" },
        "900": { "$value": "#050E1F", "$type": "color" }
      }
    },
    "semantic": {
      "bg": {
        "primary":   { "$value": "{color.primitive.white}", "$type": "color", "$description": "Default app background" },
        "secondary": { "$value": "{color.primitive.graphite.100}", "$type": "color", "$description": "Alternate surface (rare; prefer whitespace)" },
        "elevated": { "$value": "{color.primitive.white}", "$type": "color", "$description": "Tile/card background — elevation via 1px graphite-at-10% border, not shadow" },
        "inverse":   { "$value": "{color.primitive.graphite.800}", "$type": "color", "$description": "Dark Jeffrey card background; cinematic transitions" }
      },
      "fg": {
        "primary":   { "$value": "{color.primitive.graphite.800}", "$type": "color", "$description": "Primary text" },
        "secondary": { "$value": "{color.primitive.graphite.500}", "$type": "color", "$description": "Secondary text — 60-70% opacity equivalents in design" },
        "muted":     { "$value": "{color.primitive.graphite.400}", "$type": "color", "$description": "Muted text, eyebrow color — 40-50% opacity equivalents" },
        "inverse":   { "$value": "{color.primitive.white}", "$type": "color", "$description": "Text on dark surfaces" },
        "emphasis":  { "$value": "{color.primitive.signalRed.700}", "$type": "color", "$description": "Emphasis word in headline ('Understood.'); critical alerts; subscription CTA hover" },
        "data":      { "$value": "{color.primitive.aqua.500}", "$type": "color", "$description": "Data values, metric numbers, 'your data' indicators, Jeffrey 'j' avatar" }
      },
      "border": {
        "subtle":   { "$value": "{color.primitive.graphite.200}", "$type": "color", "$description": "Hairline dividers (graphite at 8% equivalent)" },
        "default":  { "$value": "{color.primitive.graphite.300}", "$type": "color", "$description": "Tile/card border (graphite at 10-16% equivalent)" },
        "strong":   { "$value": "{color.primitive.graphite.600}", "$type": "color", "$description": "Hover state borders" },
        "emphasis": { "$value": "{color.primitive.aqua.500}", "$type": "color", "$description": "Active data state borders (e.g., today in calendar grid)" }
      },
      "interactive": {
        "primary":           { "$value": "{color.primitive.graphite.800}", "$type": "color", "$description": "Default CTA fill — graphite filled" },
        "primary-hover":     { "$value": "{color.primitive.graphite.700}", "$type": "color", "$description": "CTA hover — soft graphite" },
        "primary-pressed":   { "$value": "{color.primitive.graphite.900}", "$type": "color" },
        "primary-disabled":  { "$value": "{color.primitive.graphite.300}", "$type": "color" },
        "destructive-hover": { "$value": "{color.primitive.signalRed.700}", "$type": "color", "$description": "Subscription CTA hover; one moment of red on a CTA per the 8% ratio rule" },
        "data-active":       { "$value": "{color.primitive.aqua.500}", "$type": "color", "$description": "Data-state CTA on dark cards (Apply changes button on Jeffrey recommendation card)" }
      },
      "status": {
        "live":     { "$value": "{color.primitive.aqua.500}", "$type": "color", "$description": "Listening / speaking / connected (active data)" },
        "neutral":  { "$value": "{color.primitive.graphite.500}", "$type": "color", "$description": "Thinking / pending / partial" },
        "critical": { "$value": "{color.primitive.signalRed.700}", "$type": "color", "$description": "Critical alerts only (HRV crash, system failure)" }
      }
    }
  },
  "typography": {
    "family": {
      "display": {
        "$value": "'Briston', 'IBM Plex Sans', sans-serif",
        "$type": "fontFamily",
        "$description": "Display headlines, hero typography. Bold weight only."
      },
      "system": {
        "$value": "'IBM Plex Mono', ui-monospace, 'Menlo', 'Monaco', monospace",
        "$type": "fontFamily",
        "$description": "Pre-headline labels, micro-text, button labels, code-comment sublines, table headers, data tags. The structural register."
      },
      "body": {
        "$value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Long-form text, chat captions, prose explanations"
      },
      "accent": {
        "$value": "'Baskerville', 'Libre Baskerville', 'Libre Caslon', serif",
        "$type": "fontFamily",
        "$description": "Italic accent moments only. Single use per surface max — 'Carry it forward', 'Got it. Talk soon.', cover sub-line."
      },
      "logotype": {
        "$value": "'Baskerville', 'Libre Baskerville', serif",
        "$type": "fontFamily",
        "$description": "Lowercase serif italic 'aissisted' wordmark — never IBM Plex Mono uppercase"
      }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "10":  { "$value": "10px", "$type": "dimension" },
      "11":  { "$value": "11px", "$type": "dimension", "$description": "Pre-headline labels (Plex Mono 11px / 0.18em letter-spacing standard)" },
      "12":  { "$value": "12px", "$type": "dimension" },
      "13":  { "$value": "13px", "$type": "dimension" },
      "14":  { "$value": "14px", "$type": "dimension", "$description": "Button labels, body micro-text" },
      "15":  { "$value": "15px", "$type": "dimension" },
      "16":  { "$value": "16px", "$type": "dimension", "$description": "Body default" },
      "17":  { "$value": "17px", "$type": "dimension", "$description": "User chat captions, accent body" },
      "18":  { "$value": "18px", "$type": "dimension", "$description": "Jeffrey caption, mid headlines" },
      "20":  { "$value": "20px", "$type": "dimension", "$description": "Section questions inside surfaces" },
      "22":  { "$value": "22px", "$type": "dimension" },
      "24":  { "$value": "24px", "$type": "dimension", "$description": "Headlines on small surfaces; logotype standard size" },
      "28":  { "$value": "28px", "$type": "dimension", "$description": "Causal layer headline" },
      "32":  { "$value": "32px", "$type": "dimension", "$description": "Section headlines (per spec)" },
      "36":  { "$value": "36px", "$type": "dimension" },
      "40":  { "$value": "40px", "$type": "dimension", "$description": "Subscription headline ($149/month)" },
      "56":  { "$value": "56px", "$type": "dimension", "$description": "Cover headline (Your Body. Understood.)" },
      "64":  { "$value": "64px", "$type": "dimension" }
    },
    "lineHeight": {
      "compact": { "$value": "0.92", "$type": "number", "$description": "Cover headline stack — 'Body.' period sits at cap-height of 'Understood.'" },
      "tight":   { "$value": "1.0",  "$type": "number" },
      "snug":    { "$value": "1.15", "$type": "number" },
      "normal":  { "$value": "1.45", "$type": "number" },
      "relaxed": { "$value": "1.55", "$type": "number" }
    },
    "tracking": {
      "tightest": { "$value": "-0.04em", "$type": "dimension", "$description": "Score values (Briston Bold 56px aqua score)" },
      "tighter":  { "$value": "-0.025em", "$type": "dimension", "$description": "Display headlines (Briston Bold standard)" },
      "tight":    { "$value": "-0.02em", "$type": "dimension" },
      "normal":   { "$value": "0", "$type": "dimension" },
      "wide":     { "$value": "0.06em", "$type": "dimension", "$description": "Footer micro-text, button label letter-spacing" },
      "wider":    { "$value": "0.12em", "$type": "dimension", "$description": "Status labels, code-comment register tags" },
      "widest":   { "$value": "0.18em", "$type": "dimension", "$description": "Pre-headline labels (PERSONALIZED INTELLIGENCE etc.)" },
      "max":      { "$value": "0.24em", "$type": "dimension", "$description": "Cinematic stagger labels (BUILDING)" }
    },
    "scale": {
      "logotype-md":  {
        "$value": {
          "fontFamily": "{typography.family.logotype}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.24}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.tracking.normal}",
          "fontStyle": "italic"
        },
        "$type": "typography",
        "$description": "Lowercase serif italic 'aissisted' wordmark on all surface chrome"
      },
      "pre-label":  {
        "$value": {
          "fontFamily": "{typography.family.system}",
          "fontWeight": "{typography.weight.medium}",
          "fontSize": "{typography.size.11}",
          "lineHeight": "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.tracking.widest}",
          "textCase": "uppercase"
        },
        "$type": "typography",
        "$description": "Plex Mono micro-label above headlines (EST. 2026 · PERSONALIZED INTELLIGENCE; STEP 02 / 06 · IDENTITY)"
      },
      "headline-cover":  {
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.56}",
          "lineHeight": "{typography.lineHeight.compact}",
          "letterSpacing": "{typography.tracking.tighter}"
        },
        "$type": "typography",
        "$description": "Cover surface (Your Body. / Understood.) — line-height 0.92 for the compact stack"
      },
      "headline-section":  {
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.32}",
          "lineHeight": "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.tracking.tighter}"
        },
        "$type": "typography",
        "$description": "Section headlines (What should Jeffrey call you?, How you're actually moving.)"
      },
      "headline-mid":  {
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.24}",
          "lineHeight": "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.tracking.tighter}"
        },
        "$type": "typography",
        "$description": "Sub-section headlines (Three quick reads., How was yesterday.)"
      },
      "score-large":  {
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.56}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.tracking.tightest}"
        },
        "$type": "typography",
        "$description": "Composite score (the '82' in score tile) — color: aqua"
      },
      "score-mid":  {
        "$value": {
          "fontFamily": "{typography.family.display}",
          "fontWeight": "{typography.weight.bold}",
          "fontSize": "{typography.size.28}",
          "lineHeight": "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.tracking.tighter}"
        },
        "$type": "typography",
        "$description": "Mid-size data values"
      },
      "body":  {
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.16}",
          "lineHeight": "{typography.lineHeight.relaxed}",
          "letterSpacing": "{typography.tracking.normal}"
        },
        "$type": "typography",
        "$description": "Default body text, prose summaries"
      },
      "body-caption":  {
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.14}",
          "lineHeight": "{typography.lineHeight.normal}",
          "letterSpacing": "{typography.tracking.normal}"
        },
        "$type": "typography",
        "$description": "Secondary body, sub-text under tile values"
      },
      "chat-user":  {
        "$value": {
          "fontFamily": "{typography.family.system}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.14}",
          "lineHeight": "{typography.lineHeight.relaxed}"
        },
        "$type": "typography",
        "$description": "User-side chat caption (right-aligned, IBM Plex Mono with graphite-at-4% bg)"
      },
      "chat-jeffrey":  {
        "$value": {
          "fontFamily": "{typography.family.body}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.18}",
          "lineHeight": "{typography.lineHeight.normal}"
        },
        "$type": "typography",
        "$description": "Jeffrey caption in voice modal (slightly larger; word-by-word reveal)"
      },
      "code-comment":  {
        "$value": {
          "fontFamily": "{typography.family.system}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.13}",
          "lineHeight": "{typography.lineHeight.relaxed}",
          "letterSpacing": "{typography.tracking.normal}"
        },
        "$type": "typography",
        "$description": "Code-comment voice (// listens. answers. adapts.) — typically left-aligned"
      },
      "button":  {
        "$value": {
          "fontFamily": "{typography.family.system}",
          "fontWeight": "{typography.weight.medium}",
          "fontSize": "{typography.size.14}",
          "lineHeight": "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.tracking.wide}"
        },
        "$type": "typography",
        "$description": "Pill CTA button label (Begin, Continue →, etc.)"
      },
      "tag":  {
        "$value": {
          "fontFamily": "{typography.family.system}",
          "fontWeight": "{typography.weight.medium}",
          "fontSize": "{typography.size.11}",
          "lineHeight": "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.tracking.wider}",
          "textCase": "uppercase"
        },
        "$type": "typography",
        "$description": "Status tags (REQUIRED, OPTIONAL, PREVIEW), small section labels"
      },
      "accent":  {
        "$value": {
          "fontFamily": "{typography.family.accent}",
          "fontWeight": "{typography.weight.regular}",
          "fontSize": "{typography.size.17}",
          "lineHeight": "{typography.lineHeight.normal}",
          "fontStyle": "italic"
        },
        "$type": "typography",
        "$description": "Baskerville italic accent line ('Built from your data.', 'Got it. Talk soon.', 'I'll fold this into today's read.')"
      }
    }
  },
  "spacing": {
    "0":   { "$value": "0px",   "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension" },
    "2":   { "$value": "8px",   "$type": "dimension" },
    "3":   { "$value": "12px",  "$type": "dimension" },
    "4":   { "$value": "16px",  "$type": "dimension" },
    "5":   { "$value": "20px",  "$type": "dimension" },
    "6":   { "$value": "24px",  "$type": "dimension", "$description": "Surface horizontal padding standard" },
    "7":   { "$value": "28px",  "$type": "dimension" },
    "8":   { "$value": "32px",  "$type": "dimension", "$description": "Section vertical breathing" },
    "10":  { "$value": "40px",  "$type": "dimension" },
    "12":  { "$value": "48px",  "$type": "dimension" },
    "14":  { "$value": "56px",  "$type": "dimension", "$description": "CTA button height standard" },
    "16":  { "$value": "64px",  "$type": "dimension", "$description": "Section accent gap" },
    "20":  { "$value": "80px",  "$type": "dimension", "$description": "Footer anchor from screen bottom" },
    "22":  { "$value": "88px",  "$type": "dimension", "$description": "Eyebrow lockup gap" },
    "24":  { "$value": "96px",  "$type": "dimension" },
    "32":  { "$value": "128px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0px",     "$type": "dimension" },
    "xs":   { "$value": "4px",     "$type": "dimension" },
    "sm":   { "$value": "8px",     "$type": "dimension" },
    "md":   { "$value": "12px",    "$type": "dimension", "$description": "Inputs, dashed-border drop zones" },
    "lg":   { "$value": "16px",    "$type": "dimension", "$description": "Tiles, cards, recommendation cards" },
    "xl":   { "$value": "24px",    "$type": "dimension" },
    "2xl":  { "$value": "32px",    "$type": "dimension", "$description": "Bottom-sheet top corners" },
    "phone-outer": { "$value": "56px", "$type": "dimension", "$description": "Phone-frame device chrome (Claude Design canvas mockup)" },
    "phone-inner": { "$value": "44px", "$type": "dimension", "$description": "Phone-frame inner-screen bezel (Claude Design canvas mockup)" },
    "pill": { "$value": "9999px",  "$type": "dimension", "$description": "All CTAs, chips, pill-shaped affordances. Sharp 0px corners forbidden." }
  },
  "shadow": {
    "none": { "$value": "none", "$type": "shadow" },
    "xs":   { "$value": "0 1px 2px rgba(28, 28, 30, 0.04)",   "$type": "shadow" },
    "sm":   { "$value": "0 2px 8px rgba(28, 28, 30, 0.06)",   "$type": "shadow", "$description": "State pill subtle elevation" },
    "md":   { "$value": "0 8px 24px rgba(28, 28, 30, 0.08)",  "$type": "shadow", "$description": "Floating tooltips, biomarker hover cards" },
    "lg":   { "$value": "0 24px 64px rgba(0, 194, 209, 0.32), 0 8px 24px rgba(28, 28, 30, 0.12)", "$type": "shadow", "$description": "Voice orb glow — aqua-shadowed presence" },
    "modal": { "$value": "0 32px 64px rgba(28, 28, 30, 0.16)", "$type": "shadow", "$description": "Bottom sheets, modals" }
  },
  "motion": {
    "duration": {
      "instant":  { "$value": "0ms",    "$type": "duration" },
      "micro":    { "$value": "120ms",  "$type": "duration", "$description": "Chip hover, tile hover" },
      "fast":     { "$value": "160ms",  "$type": "duration", "$description": "Button hover, transitions" },
      "exit":     { "$value": "200ms",  "$type": "duration", "$description": "Hover-out, micro-dismissals" },
      "smooth":   { "$value": "240ms",  "$type": "duration", "$description": "Surface fade-out, modal dismiss" },
      "entrance": { "$value": "320ms",  "$type": "duration", "$description": "Surface fade-in, standard reveal" },
      "stagger":  { "$value": "600ms",  "$type": "duration", "$description": "Hero word-stagger beat" },
      "gesture":  { "$value": "720ms",  "$type": "duration", "$description": "Hero fade-up, full surface entrances" },
      "ambient":  { "$value": "1200ms", "$type": "duration", "$description": "Final hold/settle" },
      "breath":   { "$value": "4000ms", "$type": "duration", "$description": "Voice orb idle breath cycle" }
    },
    "ease": {
      "out":      { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier", "$description": "Default entrance — soft landing (aissisted-system standard)" },
      "in":       { "$value": "cubic-bezier(0.7, 0, 0.84, 0)",  "$type": "cubicBezier" },
      "in-out":   { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" },
      "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)",     "$type": "cubicBezier" }
    },
    "stagger": {
      "step-1": { "$value": "0ms",    "$type": "duration" },
      "step-2": { "$value": "200ms",  "$type": "duration" },
      "step-3": { "$value": "320ms",  "$type": "duration" },
      "step-4": { "$value": "600ms",  "$type": "duration" },
      "step-5": { "$value": "900ms",  "$type": "duration" },
      "step-6": { "$value": "1100ms", "$type": "duration", "$description": "Cover hero choreography (per onboarding v2 spec): wordmark → pre-label → headline line 1 → headline line 2 (signal red) → accent line → CTA + footer" }
    }
  },
  "layout": {
    "viewport": {
      "mobile":  { "$value": "390px",  "$type": "dimension", "$description": "iPhone 14/15 baseline — primary design viewport" },
      "tablet":  { "$value": "768px",  "$type": "dimension" },
      "desktop": { "$value": "1024px", "$type": "dimension" },
      "wide":    { "$value": "1440px", "$type": "dimension" }
    },
    "maxWidth": {
      "phone":     { "$value": "380px",  "$type": "dimension", "$description": "Phone-frame outer width (Claude Design canvas mockup)" },
      "content":   { "$value": "640px",  "$type": "dimension" },
      "container": { "$value": "1200px", "$type": "dimension" }
    },
    "safeArea": {
      "top":    { "$value": "44px", "$type": "dimension", "$description": "iOS notch / status bar zone" },
      "bottom": { "$value": "34px", "$type": "dimension", "$description": "iOS home indicator zone" }
    }
  },
  "ratio": {
    "white":      { "$value": "70", "$type": "number", "$description": "Pure White — default ground" },
    "graphite":   { "$value": "20", "$type": "number", "$description": "Graphite — primary text + CTAs" },
    "softGraphite": { "$value": "—", "$type": "string", "$description": "Soft Graphite — supporting elevation; no fixed ratio" },
    "signalRed":  { "$value": "8",  "$type": "number", "$description": "Signal Red — emphasis only, max 2 elements per surface" },
    "aqua":       { "$value": "2",  "$type": "number", "$description": "Aqua — data emphasis only" },
    "midnight":   { "$value": "—", "$type": "string", "$description": "Midnight — cinematic transitions only" }
  }
}
