      "input": "What changed in my recovery this week?",
      "channel": "voice_jeffrey",
      "transcriptConfidenceOverride": 0.62,
      "expectedBehaviors": [
        "Uses clarification behavior for low confidence"
      ]
    },
    {
      "id": "HV-013",
      "personaId": "C-02",
      "input": "What changed in my recovery this week?",
      "channel": "voice_jeffrey",
      "transcriptConfidenceOverride": 0.41,
      "expectedBehaviors": [
        "Requests repeat or confirms intent before proceeding"
      ]
