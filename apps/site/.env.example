# Aissisted presentation + investor site — environment template
# Copy to .env.local for local dev; Vercel env vars hold production values.

# ── Magic-link auth (investor room) ──
# Session lifetime for investor-room sessions. Default = 14 days (Ron lock).
# Format: duration string (e.g. "14d", "24h", "7d"). Parsed at middleware level.
SITE_SESSION_EXPIRY="14d"
# Signing secret for magic-link + session tokens. 32+ chars, high-entropy.
# Generate: `openssl rand -base64 48`
SITE_SESSION_SECRET=""

# ── Jeffrey (investor persona) ──
# Anthropic API key. Milestone 10 wires the prompt + retrieval layer.
ANTHROPIC_API_KEY=""
# Model override (optional — default claude-sonnet-4-6).
JEFFREY_MODEL="claude-sonnet-4-6"

# ── CRM (HubSpot) ──
# Inbound lead pipeline for investor contacts.
HUBSPOT_ACCESS_TOKEN=""
HUBSPOT_PIPELINE_ID=""
HUBSPOT_LIFECYCLE_STAGE="lead"

# ── Infra ──
SITE_URL="https://aissisted.com"
