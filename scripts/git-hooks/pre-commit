#!/bin/bash
set -e

EXPECTED_PATH="/Users/rongibori/aissisted"
ACTUAL_PATH="$(git rev-parse --show-toplevel)"
CANONICAL_FILE="$ACTUAL_PATH/.canonical"

if [[ "$ACTUAL_PATH" == */Documents/* ]] || \
   [[ "$ACTUAL_PATH" == */Desktop/* ]] || \
   [[ "$ACTUAL_PATH" == *Mobile\ Documents* ]]; then
  echo "❌ ERROR: Working tree is in an iCloud-synced path."
  echo "   Path: $ACTUAL_PATH"
  echo "   Canonical: $EXPECTED_PATH"
  exit 1
fi

if [[ "$ACTUAL_PATH" != "$EXPECTED_PATH" ]]; then
  echo "❌ ERROR: Not at canonical path."
  echo "   Expected: $EXPECTED_PATH"
  echo "   Actual:   $ACTUAL_PATH"
  exit 1
fi

if [[ ! -f "$CANONICAL_FILE" ]]; then
  echo "❌ ERROR: .canonical marker missing at $CANONICAL_FILE"
  exit 1
fi

if ! grep -q "CANONICAL LOCAL TREE: $EXPECTED_PATH" "$CANONICAL_FILE"; then
  echo "❌ ERROR: .canonical marker doesn't declare this path canonical"
  exit 1
fi

exit 0
